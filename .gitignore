# === General ===
# Logs
logs
*.log
npm-debug.log*
lerna-debug.log*

# Dependency directories
node_modules/
jspm_packages/

# Build output
build/
dist/
public/ # If you have a web build outputting here, adjust if 'public' is source
web-build/
coverage/
*.tsbuildinfo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in projects that were created on Windows or macOS
Thumbs.db
ehthumbs.db
Desktop.ini

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz


# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# === Expo & React Native (Root Level) ===
# Expo
.expo/
expo-env.d.ts

# Metro bundler
.metro-config.js.old # Older backup if any
.metro-health-check*

# React Native generated directories (if you use 'npx expo prebuild')
# If you *do* want to commit these, remove these lines.
# However, for a clean repo relying on prebuild, these are good to ignore.
/android/
/ios/

# Example app if not part of the main codebase
app-example/


# === Rust Project (native_rust) ===
# Rust build artifacts
native_rust/target/

# UniFFI generated files within the Rust project (before copying to module)
native_rust/generated/


# === Local Expo Module (modules/zk-bindings) ===
# This section assumes that the compiled Rust libraries and generated bindings
# inside 'modules/zk-bindings' are created by 'setup_rust_bindings.mjs'
# and should not be committed to the repository.

# Android specific build artifacts for the module
modules/zk-bindings/android/build/
modules/zk-bindings/android/.gradle/
modules/zk-bindings/android/.idea/
modules/zk-bindings/android/*.iml
modules/zk-bindings/android/local.properties
modules/zk-bindings/android/.cxx/ # CMake build artifacts
modules/zk-bindings/android/.kotlin/ # Kotlin build cache

# Generated/copied Rust artifacts for Android within the module
modules/zk-bindings/android/src/main/jniLibs/
modules/zk-bindings/android/src/main/java/uniffi/

# iOS specific build artifacts for the module
modules/zk-bindings/ios/Pods/
modules/zk-bindings/ios/build/
modules/zk-bindings/ios/.xcode.env.local
modules/zk-bindings/ios/xcuserdata/
modules/zk-bindings/ios/*.xcworkspace/contents.xcworkspacedata # User-specific workspace data

# Generated/copied Rust artifacts for iOS within the module
modules/zk-bindings/ios/rust/*.a
modules/zk-bindings/ios/rust/swift/math.swift
modules/zk-bindings/ios/rust/swift/mathFFI.h
modules/zk-bindings/ios/rust/swift/mathFFI.modulemap

# Generic build folders that might appear in any module
modules/**/build/
modules/**/dist/ # If modules have their own JS build step

# === Native Platform Specific ===
# Android signing
*.jks
*.keystore
*.p8 # Can also be for APNS
*.p12

# iOS signing
*.mobileprovision
# *.pem # Generally for server certs or APNS, if not committed for a reason

# Temporary files
*.orig.*
*.bak
*.tmp

# Local environment files
.env
.env.*.local
.env.local
!.env.example # Common practice to commit an example env file

# === Other Tools ===
# Detekt (Kotlin linter)
.reports/
reports/

# SwiftLint
.swiftlint.yml # If user-specific, otherwise commit if project-wide
.swiftlint.cache

# EAS CLI metadata (often user/environment specific)
.eas/ # Keep if 'eas.json' is generic, ignore if it contains secrets or user data.
      # Your 'eas.json' seems generic, so it's likely committed.
      # If there are sub-files in .eas/ that are user-specific, ignore them:
.eas/persistent-cache/
.eas/build-configuration-cache/
